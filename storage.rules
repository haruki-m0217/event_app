rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // グループの画像（ヘッダー・投稿）は認証済みユーザーなら読み書き可
    match /groups/{groupId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // キャンパスマップ画像も認証済みユーザーなら書き込み可
    match /campus_maps/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
